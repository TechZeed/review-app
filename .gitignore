# Dependencies
node_modules/

# Build output
dist/

# Environment files
#   .env — local dev, COMMITTED. Contract: placeholder/mock values ONLY.
#          Never put real secrets here — see huddle decision d28 (2026-04-19).
#   .env.dev — real dev secrets, gitignored, bootstrap via `task dev:bundle:pull`.
.env.dev
.env.staging
.env.production
.env.local
.env.*.local

# File vault — synced to GCP Secret Manager / GitHub Secrets.
# Never commit contents. Populate locally via `task dev:vault:pull`.
# See docs/specs/22-file-vault-pattern.md.
infra/dev/vault/

# Legacy file-secret locations (migrated to infra/dev/vault/)
firebase-service-account.json
*-service-account.json

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# Test coverage
coverage/

# TypeScript cache
*.tsbuildinfo

# Docker
docker-compose.override.yml

# Apple setup helper artifacts (local)
infra/dev/.apple-browser-profile/
apps/mobile/.apple-ids.json

# Mobile build outputs only — app.json + eas.json are COMMITTED (EAS
# tarballs via git archive, so gitignored files never reach the
# sandbox; every rendered app.json produced 'com.anonymous.mobile').
# Values in app.json are public-by-design (OAuth client IDs, Firebase
# web config, Expo project ID — all ship in every APK/IPA anyway).
apps/mobile/preview.apk
apps/mobile/build.aab
inprogress.md
.deploy-env-vars.*.yaml
.claude/
