# Non-secret dev-environment identity (committed).
#
# Project + region identifiers used by bootstrap tooling (dev-bundle.ts,
# worktree-link.sh, etc.). Not secrets — these values live in CLAUDE.md
# and are part of every Cloud Run deploy command anyway.
#
# Runtime code does NOT read this file — the app reads process.env,
# populated from .env.dev locally or --set-env-vars on Cloud Run.

GCP_PROJECT_ID=humini-review
GCP_REGION=asia-southeast1
