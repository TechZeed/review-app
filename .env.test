# Review-app — TEST environment (committed; all values are fakes).
#
# Two-layer env: committed non-secret tunables (log level, review windows,
# signed-URL expiry, …) live in apps/api/config/application.test.env and
# load first. This file only holds machine-shaped values Testcontainers /
# harness needs up-front — ports, fake secrets, mock flags. `process.env`
# wins, so don't put tunables here or they'll silently override the
# committed defaults (e.g. we previously had REVIEW_TOKEN_EXPIRY_HOURS=48
# here which defeated the intentional `1`-hour fast-test window).

##### Runtime #####
NODE_ENV=test
PORT=10500

##### Postgres (Testcontainers overrides host/port at runtime) #####
POSTGRES_HOST=localhost
POSTGRES_PORT=10532
POSTGRES_DB=test_review_db
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password

##### Auth #####
JWT_SECRET=test-only-jwt-secret-do-not-reuse-in-any-other-environment
JWT_EXPIRATION_TIME_IN_MINUTES=60

##### Mocked external services #####
SMS_PROVIDER=mock
FIREBASE_PROJECT_ID=test-fake
FIREBASE_SA_PATH=./firebase-service-account.test.json
GCP_PROJECT_ID=test-fake
GCP_BUCKET_NAME=test-bucket

##### URLs #####
APP_URL=http://localhost:10500
FRONTEND_URL=http://localhost:10573
CORS_ORIGINS=http://localhost:10573,http://localhost:10574

##### E2E test credentials (consumed by Tester agent) #####
E2E_ADMIN_EMAIL=admin@test.local
E2E_ADMIN_PASSWORD=Test_Admin_Pass_007
E2E_INDIVIDUAL_EMAIL=individual@test.local
E2E_INDIVIDUAL_PASSWORD=Test_Individual_Pass_007
E2E_EMPLOYER_EMAIL=employer@test.local
E2E_EMPLOYER_PASSWORD=Test_Employer_Pass_007
E2E_RECRUITER_EMAIL=recruiter@test.local
E2E_RECRUITER_PASSWORD=Test_Recruiter_Pass_007
