# .easignore — replaces .gitignore for EAS build tarball contents.
#
# Why this exists: the root .gitignore excludes apps/mobile/app.json and
# apps/mobile/eas.json (they're rendered from .template.json by
# infra/scripts/apply-mobile-config.ts). Without this file, `eas build
# --local` uses .gitignore to build its source tarball, which means
# app.json never ships to the EAS sandbox — Expo then defaults to
# `com.anonymous.<slug>` for android.package, which Play rejects.
#
# Keep this in sync with apps/mobile/.gitignore for genuinely-useless
# files (node_modules, .expo, dist, …). Do NOT list app.json / eas.json
# here — those are what we need inside the tarball.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders — we want Expo to re-prebuild inside the sandbox
/ios
/android

# local build outputs (don't ship old AABs/APKs into the new build)
preview.apk
build.aab
