# Review-app API — TEST env defaults (committed).
#
# Loaded by integration/unit tests via Testcontainers wiring.
# Selector: APP_ENV=test.

APP_ENV=test
LOG_LEVEL=warn
ENABLE_HTTP_LOGGING=false

# Tight windows so tests hit both cold and cooldown paths quickly.
REVIEW_TOKEN_EXPIRY_HOURS=1
REVIEW_COOLDOWN_DAYS=0

SIGNED_URL_EXPIRY_MINUTES=5
