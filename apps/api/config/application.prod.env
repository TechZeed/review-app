# Review-app API — PROD env defaults (committed).
#
# See application.local.env for the pattern. Real secrets + prod-specific
# URLs never live here — they live in GCP Secret Manager / Cloud Run env vars.
# Selector: APP_ENV=prod.

APP_ENV=prod
LOG_LEVEL=info
ENABLE_HTTP_LOGGING=false

REVIEW_TOKEN_EXPIRY_HOURS=48
REVIEW_COOLDOWN_DAYS=7

SIGNED_URL_EXPIRY_MINUTES=60
