# Review-app API — DEV env defaults (committed).
#
# See application.local.env for the pattern. Values here are overridden by
# process.env (loaded from .env.dev locally, or --set-env-vars/--set-secrets
# on Cloud Run).
#
# Selector: APP_ENV=dev.

APP_ENV=dev
LOG_LEVEL=info
ENABLE_HTTP_LOGGING=false

# Non-secret dev identity — used by bootstrap tooling (dev-bundle.ts) as
# fallback when GCP_PROJECT_ID isn't in the caller env. Same values appear
# in .env.dev (real source of truth); kept here so a fresh clone can run
# `task dev:bundle:pull` before .env.dev exists.
GCP_PROJECT_ID=humini-review
GCP_REGION=asia-southeast1

# Review anti-fraud tunables — production-representative.
REVIEW_TOKEN_EXPIRY_HOURS=48
REVIEW_COOLDOWN_DAYS=7

SIGNED_URL_EXPIRY_MINUTES=60
