# Review-app API — LOCAL env defaults (committed).
#
# This file ships with the code. It holds non-secret, env-varying defaults that
# the app loads at startup. Actual secrets and machine-specific values live in
# the repo-root `.env` (gitignored) and override anything here.
#
# Selector: APP_ENV=local (run.sh and Taskfile.local.yml export this).
# Never put secrets here. Never put anything here that isn't safe to commit.

APP_ENV=local
LOG_LEVEL=debug
ENABLE_HTTP_LOGGING=true

# Review anti-fraud tunables — short windows for local testing.
REVIEW_TOKEN_EXPIRY_HOURS=48
REVIEW_COOLDOWN_DAYS=0

# Storage defaults (real bucket only used in dev/prod; local stays mock).
SIGNED_URL_EXPIRY_MINUTES=60
