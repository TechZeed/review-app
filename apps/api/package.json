{
  "name": "review-app-api",
  "version": "0.1.0",
  "description": "Portable Individual Review/Reputation API",
  "license": "ISC",
  "author": "Muthukumaran Navaneethakrishnan",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "tsx --env-file=.env src/db/cli.ts up",
    "db:migrate:down": "tsx --env-file=.env src/db/cli.ts down",
    "db:migrate:status": "tsx --env-file=.env src/db/cli.ts status",
    "db:seed": "tsx --env-file=.env src/db/seed-cli.ts up",
    "db:seed:down": "tsx --env-file=.env src/db/seed-cli.ts down",
    "db:seed:status": "tsx --env-file=.env src/db/seed-cli.ts status",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "echo '\n  API docs at http://localhost:3000/api-docs\n'"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.18.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.5",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.7",
    "stripe": "^14.25.0",
    "umzug": "^3.8.2",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
