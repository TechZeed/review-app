# ============================================================================
# .env — LOCAL DEV DEFAULTS (committed to git).
#
# CONTRACT: every value here must be a placeholder, mock, or local-only
# identifier. NEVER put a real secret in this file. Real dev secrets live
# in .env.dev (gitignored, bootstrapped via `task dev:bundle:pull`).
#
# If you need a real value for local debugging, put it in .env.dev and run
# APP_ENV=dev — do not pollute .env. See huddle decision d28 (2026-04-19)
# and docs/specs/22-file-vault-pattern.md.
# ============================================================================

NODE_ENV=development

# Local API port (651x range). Cloud Run injects PORT=8080 at runtime separately.
PORT=6510

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=6519
POSTGRES_DB=review_app
POSTGRES_USER=review_user
POSTGRES_PASSWORD=changeme

# Auth
JWT_SECRET=local-dev-secret-must-be-at-least-thirty-two-characters-long
JWT_EXPIRATION_TIME_IN_MINUTES=60

# Seed / regression — shared password for demo users (ramesh@, priya@, etc.)
DEFAULT_SEED_PASSWORD=Demo123

# Firebase (mock mode for local dev)
FIREBASE_PROJECT_ID=local-dev

# Storage (mock for local dev)
GCP_BUCKET_NAME=local-dev-bucket
GCP_PROJECT_ID=local-dev
SIGNED_URL_EXPIRY_MINUTES=60

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# SMS (mock mode)
SMS_PROVIDER=mock

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
REVIEW_TOKEN_EXPIRY_HOURS=48
REVIEW_COOLDOWN_DAYS=7

ENABLE_HTTP_LOGGING=false

# Frontend build args (Vite)
VITE_PUBLIC_REVIEW_URL=http://localhost:5173
# Show email+password sign-in affordance in local dev (testing).
VITE_FEATURE_EMAIL_LOGIN=true
EXPO_PUBLIC_FEATURE_EMAIL_LOGIN=true
